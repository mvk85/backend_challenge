# HTTP port for the NestJS backend API.
PORT=3001

# Command used to start the GitHub MCP server process.
MCP_GITHUB_COMMAND=npx

# Arguments passed to MCP_GITHUB_COMMAND.
# Default runs the official GitHub MCP server package via npx.
MCP_GITHUB_ARGS=-y @modelcontextprotocol/server-github

# GitHub Personal Access Token used by the GitHub MCP server.
# Required: without this token, provider connection will fail.
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token

# Timeout (ms) for MCP operations such as connect/listTools/callTool.
MCP_CALL_TIMEOUT_MS=20000

# Backend file storage directory used by /downloads/:fileId endpoint.
FILE_STORAGE_DIR=./storage/files

# ProxyAPI/OpenAI config for built-in llm MCP provider (/mcp/llm/...)
# API key can be reused from first_api (.env): VITE_OPENAI_API_KEY.
# For backend prefer non-VITE names below.
PROXYAPI_OPENAI_API_KEY=
PROXYAPI_OPENAI_API_URL=https://openai.api.proxyapi.ru/v1/chat/completions
PROXYAPI_OPENAI_MODEL=gpt-5.1

# Optional list of additional MCP providers in JSON format (single-line JSON array).
# Backend loads this value on startup and registers each provider in /mcp/providers.
# Format:
# [
#   {
#     "id": "provider-id",              // required, unique provider name used in URL: /mcp/:provider/...
#     "command": "node|npx|...",        // required, process executable
#     "args": ["arg1", "arg2"],         // optional, command arguments array
#     "env": { "KEY": "VALUE" },        // optional, extra env vars for this MCP process only
#     "timeoutMs": 20000                // optional, call timeout override for this provider
#   }
# ]
# Notes:
# - Value must be valid JSON (double quotes only).
# - Keep it in one line in .env to avoid parser issues.
# - Relative paths are resolved from backend working directory.
# Example for local file-tools MCP server:
# MCP_EXTERNAL_PROVIDERS_JSON=[{"id":"file-tools","command":"node","args":["mcp-servers/file-tools-mcp/index.js"],"env":{"FILE_TOOLS_STORAGE_DIR":"./storage/files","FILE_TOOLS_PUBLIC_BASE_URL":"http://localhost:3001"},"timeoutMs":20000}]
MCP_EXTERNAL_PROVIDERS_JSON=
